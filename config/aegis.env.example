AEGIS_LISTEN_ADDR=:8080
AEGIS_UPSTREAM_URL=http://127.0.0.1:9090/mcp
AEGIS_JWT_SHARED_SECRET=replace-me
AEGIS_JWT_ISSUER=
AEGIS_JWT_AUDIENCE=
AEGIS_JWT_REQUIRE_AUDIENCE=false
AEGIS_JWT_ALLOWED_CLOCK_SKEW=30s
AEGIS_POLICY_FILE=config/policy.rego
AEGIS_POLICY_RELOAD_INTERVAL=5s
AEGIS_UPSTREAM_TIMEOUT=30s
AEGIS_READ_TIMEOUT=10s
AEGIS_READ_HEADER_TIMEOUT=5s
AEGIS_WRITE_TIMEOUT=15s
AEGIS_IDLE_TIMEOUT=60s
AEGIS_DECISION_TIMEOUT=5s
AEGIS_MAX_BODY_BYTES=1048576
AEGIS_METRICS_NAMESPACE=aegis_mcp
AEGIS_SEMANTIC_FAIL_CLOSED=true
AEGIS_SEMANTIC_MINIMUM_SCORE=0.35
AEGIS_SEMANTIC_BLOCKED_INTENTS=prompt_injection,jailbreak_attempt,malicious_code_generation,secret_exfiltration
